# Copy this file to .env.local and fill in the values from your Supabase project.
# Supabase Dashboard -> Project Settings -> API

# Your project URL, e.g. https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The PUBLIC anon key (safe to expose in the browser; RLS is the security boundary).
# Do NOT put the service-role key here — it is never used by this app.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
